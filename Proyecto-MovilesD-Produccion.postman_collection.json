{
	"info": {
		"name": "Proyecto-MovilesD-Produccion",
		"description": "Colección de endpoints para Diaz Moviles - Producción",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "https://diaz-moviles.uaeftt-ute.site",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set(\"token\", jsonData.access);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{"key": "Content-Type", "value": "application/json"}],
				"body": {
					"mode": "raw",
					"raw": "{\"username\": \"admin\", \"password\": \"admin123\"}"
				},
				"url": {
					"raw": "https://diaz-moviles.uaeftt-ute.site/api/token/",
					"host": ["https://diaz-moviles.uaeftt-ute.site"],
					"path": ["api", "token", ""]
				}
			}
		},
		{
			"name": "Marcas",
			"item": [
				{
					"name": "Listar",
