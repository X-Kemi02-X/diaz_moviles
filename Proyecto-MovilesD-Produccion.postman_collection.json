				},
				{
					"name": "Actualizar",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"nombre\": \"Google LLC\", \"pais_origen\": \"Estados Unidos\", \"activo\": true}"},
						"url": {"raw": "{{base_url}}/api/marcas/1/", "host": ["{{base_url}}"], "path": ["api", "marcas", "1", ""]}
					}
				},
